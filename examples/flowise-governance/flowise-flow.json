        "type": "CustomFunction",
        "baseClasses": [
          "CustomFunction"
        ],
        "category": "Utilities",
        "description": "Parse sidecar response and return allow/block message",
        "inputParams": [
          {
            "label": "Function Name",
            "name": "functionName",
            "type": "string",
            "default": "fn",
            "id": "customFunction_1-input-functionName-string"
